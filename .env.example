# Kopieer naar .env.local en vul waarden in.

# Supabase (client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only; service role / secret key)
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # alternatief voor SUPABASE_SECRET_KEY

# OpenAI
OPENAI_API_KEY=

# TwinWord sentiment (optioneel)
RAPIDAPI_KEY=
# TWINWORD_ENABLED=false
# TWINWORD_MONTHLY_LIMIT=

# Registratie
REGISTRATION_INVITE_CODE=

# Dagelijkse check-in scheduler (productie + handmatige curl-test)
CRON_SECRET=

# Database-migraties (lokaal: npm run db:migrate)
SUPABASE_DB_URL=

# Contactformulier (e-mailnotificatie via Resend)
RESEND_API_KEY=
CONTACT_NOTIFY_TO=tessavermeulen@icloud.com
CONTACT_FROM=Lumina <onboarding@resend.dev>

# Optioneel: private entry unlock (fallback naar service role key)
# ENTRY_UNLOCK_SECRET=
